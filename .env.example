# AnySearch API Configuration
# ================================================
# Copy this file to .env.local and fill in your API key
# 複製此檔案為 .env.local，然後填入你的 API key
#
# Get your API key at https://www.anysearch.com
# 在 https://www.anysearch.com 申請 API key

ANYSEARCH_API_KEY=your_key_here

# Optional: AnySearch API endpoint (default: https://api.anysearch.com)
# 選項：AnySearch API 端點（預設：https://api.anysearch.com）
# ANYSEARCH_API_ENDPOINT=https://api.anysearch.com

# Optional: Windsurf MCP SSE proxy port (default: 8000)
# 選項：Windsurf MCP SSE proxy 連接埠（預設：8000）
# ANYSEARCH_MCP_PORT=8000
